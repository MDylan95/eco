# PostgreSQL
# IMPORTANT: avec le docker-compose actuel, PostgreSQL est exposé en 5433
# (si vous utilisez PostgreSQL local en 5432, changez manuellement en 5432)
DATABASE_URL=postgres://eco:ecopass@localhost:5433/ecomanager

# Mots de passe initiaux (en production, utilisez des valeurs fortes)
ADMIN_INIT_PASSWORD=admin123
SUPERVISEUR_INIT_PASSWORD=super123

# db:init est destructif : activez explicitement en production uniquement
FORCE_DB_INIT=false

# Auth
JWT_SECRET=change-me-in-production-please
JWT_EXPIRES_IN=12h

# Server
PORT=4000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
